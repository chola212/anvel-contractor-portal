NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key"
SUPABASE_SERVICE_ROLE_KEY="your-server-only-service-role-key"
NEXT_PUBLIC_SITE_URL="https://portal.anvelconsulting.com"

# Required branded email provider for contractor invites, password resets and
# generated invoice email. The portal must not send default platform emails.
RESEND_API_KEY=""
PORTAL_EMAIL_FROM="ANVEL Consulting <contact@anvelconsulting.com>"
ADMIN_NOTIFICATION_EMAIL="contact@anvelconsulting.com"

# If your Supabase dashboard only shows a legacy "anon public" key,
# paste that value into NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for now.
# NEXT_PUBLIC_SUPABASE_ANON_KEY is also accepted for older Supabase projects.
